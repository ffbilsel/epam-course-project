{
  "name": "innovatepam-portal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:admin": "tsx scripts/seed-admin.ts",
    "db:reset": "node -e \"require('fs').rmSync('./data/innovatepam.db',{force:true})\"",
    "check:error-codes": "tsx scripts/check-error-codes.ts",
    "check:ui-tokens": "tsx scripts/check-ui-tokens.ts",
    "presentation:pdf": "tsx scripts/presentation-to-pdf.ts",
    "check": "npm run typecheck && npm run lint && npm run format && npm run test:unit",
    "setup:hooks": "pwsh -File scripts/install-hooks.ps1"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.4.2",
    "@hookform/resolvers": "^3.9.0",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "diff": "^5.2.2",
    "drizzle-orm": "^0.33.0",
    "file-type": "^19.5.0",
    "lucide-react": "^0.439.0",
    "next": "^14.2.13",
    "next-auth": "5.0.0-beta.20",
    "nodemailer": "^6.10.1",
    "pino": "^9.4.0",
    "rate-limiter-flexible": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "recharts": "^2.15.4",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.45.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/diff": "^5.2.3",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^6.4.23",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.13",
    "eslint-plugin-jsdoc": "^50.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "glob": "^13.0.6",
    "jsdom": "^25.0.0",
    "pino-pretty": "^11.2.2",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.19.1",
    "typescript": "~5.4.5",
    "vitest": "^1.6.1"
  }
}
