# NextAuth
NEXTAUTH_SECRET=replace-me-with-32-random-bytes-base64
NEXTAUTH_URL=http://localhost:3000

# Bootstrap admin (FR-005b)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Database (better-sqlite3 file path)
DATABASE_URL=file:./data/innovatepam.db

# Phase 5 — Email (SMTP relay; nodemailer ADR-0023)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
MAIL_FROM=InnovatePAM <no-reply@innovatepam.local>

# Phase 5 — Notification dispatcher (ms between dispatcher wake-ups)
NOTIFICATION_POLL_INTERVAL_MS=1000
